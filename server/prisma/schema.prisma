generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  city         String?
  preferences  Json?
  createdAt    DateTime   @default(now())
  bookings     Booking[]
  reviews      Review[]
  activities   Activity[]
}

model Event {
  id           String     @id @default(cuid())
  title        String
  category     String
  venue        String
  city         String
  dateTime     DateTime
  posterUrl    String?
  description  String
  language     String?
  durationMins Int
  status       String     @default("active")
  seats        Seat[]
  bookings     Booking[]
  reviews      Review[]
  activities   Activity[]
}

model Seat {
  id       String  @id @default(cuid())
  eventId  String
  row      String
  column   Int
  category String
  price    Float
  isBooked Boolean @default(false)
  event    Event   @relation(fields: [eventId], references: [id])
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  seatIds   String[]
  total     Float
  status    String   @default("pending")
  paymentId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  action    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}